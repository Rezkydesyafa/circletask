{
  "name": "circletask",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit",
    "test:unit": "tsc -p tsconfig.test.json && node --test .tmp/tests/features/contributions/calculate.test.js .tmp/tests/features/tasks/state-machine.test.js",
    "test:contribution": "tsc -p tsconfig.test.json && node --test .tmp/tests/features/contributions/calculate.test.js",
    "test:supabase": "tsc -p tsconfig.integration.json && node --test .tmp/integration/scripts/supabase-smoke-test.js",
    "supabase:migrate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/apply-supabase-backend.ps1",
    "supabase:migrate:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/apply-supabase-backend.ps1 -Local -GenerateTypes",
    "supabase:types": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-supabase-types.ps1 -Local"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@react-pdf/renderer": "^4.1.5",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.46.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "next": "^14.2.23",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.23",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
